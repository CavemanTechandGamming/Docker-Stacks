TZ=America/New_York

# Multi-arch (amd64 + arm64); good default for Raspberry Pi and small hosts
OCSERV_IMAGE=cherts/ocserv:latest

# Host ports forwarded to ocserv (inside the container ocserv still listens on HC_TCP_PORT / HC_UDP_PORT)
OCSERV_PUBLISH_TCP_PORT=443
OCSERV_PUBLISH_UDP_PORT=443

# Inside-container ports (usually keep 443 unless you customize ocserv.conf)
HC_TCP_PORT=443
HC_UDP_PORT=443

# Common name embedded in the auto-generated server cert (set to your LAN hostname or VPN DNS name)
HC_SRV_CN=vpn.lan

# Persisted: certs, ocpasswd, ocserv.conf once generated
OCSERV_CONFIG_DIR=./config

# Set to any non-empty value to skip the default “test” user (you must manage ocpasswd yourself)
# HC_NO_TEST_USER=1
