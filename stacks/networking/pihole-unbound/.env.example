# Timezone (IANA)
TZ=America/New_York

# Images (pin tags or digests for production)
PIHOLE_IMAGE=pihole/pihole:latest
UNBOUND_IMAGE=docker.io/klutchell/unbound:latest

# Pi-hole admin UI (set in .env — do not commit real passwords)
# If unset, Pi-hole assigns a random password; check container logs for it.
PIHOLE_WEBPASSWORD=

# Host ports (53 often needs a dedicated Linux host or free port; see README for Windows)
PIHOLE_DNS_TCP=53
PIHOLE_DNS_UDP=53
PIHOLE_HTTP_PORT=8080
PIHOLE_HTTPS_PORT=8443
# PIHOLE_DHCP=67
