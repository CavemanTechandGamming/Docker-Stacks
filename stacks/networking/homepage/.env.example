# Homepage — https://gethomepage.dev/
# Pin the image in production: https://github.com/gethomepage/homepage/pkgs/container/homepage

HOMEPAGE_IMAGE=ghcr.io/gethomepage/homepage:latest
HOMEPAGE_CONTAINER_NAME=homepage
HOMEPAGE_PORT=3000

# Required when you open Homepage using a host other than localhost / 127.0.0.1
# (comma-separated, no spaces). Examples:
#   HOMEPAGE_ALLOWED_HOSTS=192.168.1.50:3000,home.lan
#   HOMEPAGE_ALLOWED_HOSTS=dash.example.com
# See: https://gethomepage.dev/installation/#homepage_allowed_hosts
HOMEPAGE_ALLOWED_HOSTS=

# Config directory (YAML + assets). Create ./config before first run or let Docker create files.
HOMEPAGE_CONFIG_DIR=./config
