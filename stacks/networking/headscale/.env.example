# Copy to `.env` in this stack directory before `docker compose up`.
HEADSCALE_IMAGE=headscale/headscale:0.25.1

# Host publishes container 8080 (HTTP API) and 9090 (Prometheus metrics).
HEADSCALE_HTTP_PORT=8088
HEADSCALE_METRICS_PORT=9190

# SQLite + keys under this directory on the host.
HEADSCALE_LIB_DIR=./lib
