# Dashboard container environment (see https://docs.netbird.io/selfhosted/configuration-files#dashboardenv).
# Edit the hostnames to match `config/config.yaml` (management `exposedAddress` + `server.auth.issuer`).

# Where the browser reaches the NetBird management API / gRPC (usually your reverse-proxy HTTPS URL).
NETBIRD_MGMT_API_ENDPOINT=https://netbird.example.com
NETBIRD_MGMT_GRPC_API_ENDPOINT=https://netbird.example.com

# Embedded IdP (Dex) — keep in sync with `server.auth.issuer` in config.yaml.
AUTH_AUDIENCE=netbird-dashboard
AUTH_CLIENT_ID=netbird-dashboard
AUTH_CLIENT_SECRET=
AUTH_AUTHORITY=https://netbird.example.com/oauth2
USE_AUTH0=false
AUTH_SUPPORTED_SCOPES=openid profile email groups
AUTH_REDIRECT_URI=/nb-auth
AUTH_SILENT_REDIRECT_URI=/nb-silent-auth

# TLS is expected to be handled by a reverse proxy; embedded nginx serves HTTP on port 80 inside the container.
NGINX_SSL_PORT=443
LETSENCRYPT_DOMAIN=none
