# Copy to `.env` in this stack directory (Compose variable substitution / shared settings).
NETBIRD_SERVER_IMAGE=netbirdio/netbird-server:0.65.3
NETBIRD_DASHBOARD_IMAGE=netbirdio/dashboard:v2.37.1

# Host port → container 80 (HTTP + gRPC/h2c on the combined server; terminate TLS in front).
NETBIRD_SERVER_HTTP_PORT=8091
NETBIRD_DASHBOARD_HTTP_PORT=8092

# STUN (UDP) must be reachable from the public internet for many NAT scenarios.
NETBIRD_STUN_PORT=3478

# Persistent SQLite + keys for the combined server.
NETBIRD_LIB_DIR=./lib
