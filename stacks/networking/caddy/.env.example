# Image (pin a digest or minor version for production)
# CADDY_IMAGE=caddy:2-alpine

# Published ports
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDY_HTTP3_UDP_PORT=443

# ACME / data paths on the host (relative to this stack dir unless absolute)
# CADDY_DATA_DIR=./data
# CADDY_CONFIG_DIR=./config

# Shared edge network — other stacks use the same name with `external: true`
EDGE_NETWORK_NAME=homelab_edge
