PUID=1000
PGID=1000
TZ=America/New_York

# External hostname or IP for clients (use `auto` to detect, or your DDNS name)
WG_SERVERURL=auto

# UDP port on the Docker host (must be forwarded from your router for road-warrior use)
WG_SERVERPORT=51820

# Number of peers, or comma-separated names: laptop,phone,tablet
WG_PEERS=1

# DNS pushed to clients — `auto` uses host DNS via image’s CoreDNS helper; or e.g. 10.0.0.1 / your Pi-hole IP
WG_PEERDNS=auto

# VPN tunnel subnet (change if it clashes with your LAN)
WG_INTERNAL_SUBNET=10.13.13.0

# What clients route through the tunnel (default: all IPv4)
WG_ALLOWEDIPS=0.0.0.0/0

# Print QR codes to container logs on first gen
WG_LOG_CONFS=true

# WIREGUARD_IMAGE=lscr.io/linuxserver/wireguard:latest

# Persistent config (peer keys, wg0.conf) — path relative to this stack
# WG_CONFIG_DIR=./config
