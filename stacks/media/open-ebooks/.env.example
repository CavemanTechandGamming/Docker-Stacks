# IRC nick required by OpenBooks when connecting to Irchighway (pick something unique).
OPENBOOKS_IRC_NAME=your-unique-nick

OPENBOOKS_IMAGE=evanbuss/openbooks:latest
OPENBOOKS_PORT=8080
OPENBOOKS_BOOKS_DIR=./books

# Optional: set BASE_PATH for a reverse-proxy subpath — add an `environment:` block to compose.yaml
# per https://evan-buss.github.io/openbooks/configuration/
