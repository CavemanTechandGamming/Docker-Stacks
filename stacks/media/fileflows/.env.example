# Copy to `.env` in this stack directory.
FILEFLOWS_IMAGE=revenz/fileflows:26.04

# Web UI (container listens on 5000; upstream default host port is 19200).
FILEFLOWS_HTTP_PORT=19200

# IANA timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=UTC

# Host paths — use a fast disk for temp (per FileFlows docs).
FILEFLOWS_DATA_DIR=./data
FILEFLOWS_TEMP_DIR=./temp
FILEFLOWS_MEDIA_DIR=./media
FILEFLOWS_DOCKERMODS_DIR=./dockermods

# Optional: other image tracks (see https://hub.docker.com/r/revenz/fileflows)
# FILEFLOWS_IMAGE=revenz/fileflows:stable
# FILEFLOWS_IMAGE=revenz/fileflows:latest
