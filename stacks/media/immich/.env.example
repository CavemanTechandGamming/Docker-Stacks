# Timezone (IANA)
TZ=America/New_York

# Immich release tag — pin a version for production: https://github.com/immich-app/immich/releases
IMMICH_VERSION=release

# Web UI port on the host
IMMICH_PORT=2283

# Database (use only A–Z, a–z, 0–9 in DB_PASSWORD per Immich docs)
DB_USERNAME=postgres
DB_PASSWORD=changeMeToRandomAlphanumeric
DB_DATABASE_NAME=immich

# Redis / Valkey
REDIS_PORT=6379
VALKEY_IMAGE=docker.io/valkey/valkey:9-alpine

# Vector Postgres image required by Immich (pin for production)
IMMICH_POSTGRES_IMAGE=ghcr.io/immich-app/postgres:14-vectorchord0.4.3-pgvectors0.2.0
