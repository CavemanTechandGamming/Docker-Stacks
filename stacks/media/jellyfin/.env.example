# Timezone (IANA)
TZ=America/New_York

# Image (pin a version tag for production)
JELLYFIN_IMAGE=jellyfin/jellyfin:latest

# Run as host UID:GID for consistent file permissions on volumes
JELLYFIN_UID_GID=1000:1000

# Web UI
JELLYFIN_HTTP_PORT=8096

# Optional: public URL when behind reverse proxy (e.g. https://jellyfin.example.com)
JELLYFIN_PUBLISHED_SERVER_URL=

# Media root in container is /media — set host path or use default named volume
# JELLYFIN_MEDIA_DIR=/path/to/your/media
