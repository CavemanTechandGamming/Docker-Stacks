# Audiobookshelf — https://www.audiobookshelf.org/
# Pin the image tag in production: https://github.com/advplyr/audiobookshelf/pkgs/container/audiobookshelf

AUDIOBOOKSHELF_IMAGE=ghcr.io/advplyr/audiobookshelf:latest

ABS_HTTP_PORT=13378
TZ=UTC

# Host paths (relative to this stack folder, or absolute). Create dirs or point at your NAS.
ABS_AUDIOBOOKS_DIR=./audiobooks
ABS_PODCASTS_DIR=./podcasts
ABS_METADATA_DIR=./metadata
ABS_CONFIG_DIR=./config
