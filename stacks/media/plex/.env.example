# Timezone (IANA)
TZ=America/New_York

# LinuxServer Plex image (pin for production)
PLEX_IMAGE=lscr.io/linuxserver/plex:latest

# Container update channel for VERSION (docker, latest, etc.)
PLEX_VERSION=docker

# Host user/group for file ownership on /config and /data
PUID=1000
PGID=1000

# Web UI and API
PLEX_HTTP_PORT=32400

# Optional: claim token from https://www.plex.tv/claim/ (expires ~4 minutes after generation)
PLEX_CLAIM=

# Media library root inside the container is /data — map host path below or use default named volume
# PLEX_MEDIA_DIR=/path/to/your/media
