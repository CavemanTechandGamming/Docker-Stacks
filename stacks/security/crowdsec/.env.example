# Published Local API → host (plan firewall rules; localhost-only via Docker Desktop publish policies).
CROWDSEC_LAPI_PORT=8980

# Hub collections prefetched at container start — override for minimal footprint.
CROWDSEC_COLLECTIONS=crowdsecurity/linux

