# Strong random values — keep out of Git.
# AUTHENTIK_SECRET_KEY: prefer hex (e.g. openssl rand -hex 32) so Docker Compose’s .env parser is not tripped by unquoted base64 “/” or “+” characters.
PG_PASS=
AUTHENTIK_SECRET_KEY=

# Optional overrides
# PG_USER=authentik
# PG_DB=authentik
# AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
# AUTHENTIK_TAG=2025.10.4

# Host ports → container HTTP/HTTPS bootstrap listeners
AUTHENTIK_HTTP_PORT=9000
AUTHENTIK_HTTPS_PORT=9443
