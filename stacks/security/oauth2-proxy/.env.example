# Required by compose (copy to `.env`; do not commit real secrets).

# openssl rand -base64 32 | tr '+/' '-_'
OAUTH2_PROXY_COOKIE_SECRET=generate_a_urlsafe_base64_secret

# Public callback URL MUST match OAuth app registration exactly.
OAUTH2_PROXY_REDIRECT_URL=http://localhost:4180/oauth2/callback

# Required for GitHub/Google-style providers — must match what you authorize at the IdP (`*` permits any validated email until you tighten it).
OAUTH2_PROXY_EMAIL_DOMAIN=*

# Upstream served after successful login (often your app or Caddy vhost upstream).
OAUTH2_PROXY_UPSTREAMS=http://host.docker.internal:8080/

# --- Example: GitHub ---
OAUTH2_PROXY_PROVIDER=github
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=

# Generic OIDC (uncomment set and adjust provider block as needed instead of github):
# OAUTH2_PROXY_PROVIDER=oidc
# OAUTH2_PROXY_CLIENT_ID=
# OAUTH2_PROXY_CLIENT_SECRET=
# OAUTH2_PROXY_OIDC_ISSUER_URL=https://your-idp.example.com

# OPTIONAL pin:
# OAUTH2_PROXY_IMAGE=quay.io/oauth2-proxy/oauth2-proxy:v7.7.1

# TZ=UTC
