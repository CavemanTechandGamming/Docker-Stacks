# Public URL of this Vaultwarden instance (scheme required). Behind Caddy, use your HTTPS vhost.
# Local testing: http://localhost:8080 (match VAULTWARDEN_PORT)
VAULTWARDEN_DOMAIN=http://localhost:8080

# Admin panel (/admin) — generate e.g. openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=change_me_to_a_long_random_token

# Host port → container 80
VAULTWARDEN_PORT=8080

# After creating your first user, set SIGNUPS_ALLOWED=false in .env and recreate the container.
VAULTWARDEN_SIGNUPS_ALLOWED=true
VAULTWARDEN_INVITATIONS_ALLOWED=true

# WebSocket helps live sync; keep true especially behind a reverse proxy (Caddy).
# VAULTWARDEN_ENABLE_WEBSOCKET=true

# Timezone (IANA)
TZ=America/New_York

# VAULTWARDEN_IMAGE=vaultwarden/server:latest
