# --- Required (no real defaults; copy to .env and fill in) ---
# Public URL you use in the browser (must match how you reach the Command Center)
NOMAD_URL=http://localhost:8080

# Min 16 characters; used by the admin app
NOMAD_APP_KEY=change_me_to_a_long_random_secret

# MySQL — app user password (must match between admin and mysql services)
NOMAD_DB_PASSWORD=change_me_strong_db_password

# MySQL root password (separate from app user)
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# --- Optional ---
# NOMAD_IMAGE=ghcr.io/crosstalk-solutions/project-nomad:latest
# NOMAD_PULL_POLICY=always
# NOMAD_HTTP_PORT=8080
# DOZZLE_HTTP_PORT=9999
# NOMAD_LOG_LEVEL=info
# NOMAD_DISABLE_COMPRESSION=false

# Data directories (relative to this stack folder unless you use absolute paths)
# NOMAD_STORAGE_DIR=./storage
# NOMAD_MYSQL_DIR=./mysql
# NOMAD_REDIS_DIR=./redis

# Directory mounted as /opt/project-nomad for the updater sidecar (use stack root, where compose.yml lives)
# NOMAD_INSTALL_DIR=.

# DOZZLE_IMAGE=amir20/dozzle:v10.0
# MYSQL_IMAGE=mysql:8.0
# REDIS_IMAGE=redis:7-alpine
# NOMAD_UPDATER_IMAGE=ghcr.io/crosstalk-solutions/project-nomad-sidecar-updater:latest
# NOMAD_DISK_COLLECTOR_IMAGE=ghcr.io/crosstalk-solutions/project-nomad-disk-collector:latest
