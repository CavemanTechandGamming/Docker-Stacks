TZ=America/New_York

# Pin tags in production after verifying upgrades.
PROMETHEUS_IMAGE=prom/prometheus:latest
GRAFANA_IMAGE=grafana/grafana:latest
LOKI_IMAGE=grafana/loki:latest
PROMTAIL_IMAGE=grafana/promtail:latest

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100

# Change before exposing Grafana beyond localhost
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-to-a-strong-secret

# Public URL Grafana uses for links (set to your HTTPS URL behind Caddy, etc.)
GRAFANA_ROOT_URL=http://localhost:3000

# Host Docker socket (Linux / Docker Desktop WSL2 default)
# DOCKER_SOCK=/var/run/docker.sock
