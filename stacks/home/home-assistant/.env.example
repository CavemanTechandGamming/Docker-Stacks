# Timezone
TZ=America/New_York

# Image (pin stable or a specific version after first working setup)
HOMEASSISTANT_IMAGE=ghcr.io/home-assistant/home-assistant:stable

# Web UI
HOMEASSISTANT_PORT=8123

# Config and state (database, YAML, add-ons data layout lives here)
HOMEASSISTANT_CONFIG_DIR=./config
