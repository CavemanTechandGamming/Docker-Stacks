# Password for NUT API (upsmon / remote monitors must match)
NUT_API_PASSWORD=change_me_strong_nut_password
NUT_API_USER=upsmon

# UPS name in NUT (single UPS default)
NUT_UPS_NAME=ups

# Driver — see https://networkupstools.org/stable-hcl.html
NUT_DRIVER=usbhid-ups

# APC usbhid-ups often needs the 12-digit serial from lsusb -v (leave empty if not required)
NUT_SERIAL=

# Device: auto (USB scan) or e.g. /dev/ttyUSB0
NUT_PORT=auto

# CyberPower and some units may need MAXAGE > 25
NUT_MAXAGE=25

# Optional: Tripp Lite etc. — hex without 0x (see image README)
# NUT_VENDORID=

# Host port for upsd (NUT protocol)
NUT_UPSD_PORT=3493

# Drop custom ups.conf / upsmon.conf here: ./local/ → /etc/nut/local (see upsmon.local.example)
# NUT_LOCAL_CONF_DIR=./local

# NUT_IMAGE=instantlinux/nut-upsd:latest
