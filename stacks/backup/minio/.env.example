# Pin intentionally — see https://hub.docker.com/r/minio/minio/tags
MINIO_IMAGE=minio/minio:RELEASE.2025-01-20T14-49-07Z

# S3 API (clients, apps, restic with S3 backend).
MINIO_API_PORT=9000
# Web console (create buckets, keys).
MINIO_CONSOLE_PORT=9001

MINIO_DATA_DIR=./data

# Root credentials — treat as secrets; rotate if exposed.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
