REST_SERVER_IMAGE=restic/rest-server:latest
REST_SERVER_PORT=8000

# Repository files live here (include .htpasswd unless using DISABLE_AUTHENTICATION).
RESTIC_DATA_DIR=./data

# Extra flags for rest-server, e.g. --append-only --prometheus
REST_SERVER_OPTIONS=--append-only

# Trusted LAN only: omit .htpasswd requirement (do not expose to the internet).
# DISABLE_AUTHENTICATION=1
