# LinuxServer Duplicati — match IDs to the user that should own /config (Linux hosts).
PUID=1000
PGID=1000
TZ=America/New_York

# Web UI
DUPLICATI_PORT=8200

# Local state (job DB, cache — may contain sensitive metadata; not for Git)
# DUPLICATI_CONFIG_DIR=./config

# What to back up (read-only in container at /source). Use a host path for real data, e.g.:
# DUPLICATI_SOURCE_DIR=/path/to/photos
# Or keep ./source and add extra bind mounts in compose.yaml.
DUPLICATI_SOURCE_DIR=./source

# DUPLICATI_IMAGE=lscr.io/linuxserver/duplicati:latest
