# LinuxServer Nextcloud
PUID=1000
PGID=1000
TZ=America/New_York

# Host port → container HTTPS (image uses TLS on 443 by default). Avoid 443 if Caddy binds it.
NEXTCLOUD_HTTPS_PORT=4443

# NEXTCLOUD_IMAGE=lscr.io/linuxserver/nextcloud:latest

# MariaDB
MYSQL_ROOT_PASSWORD=change_me_strong_root_password
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=change_me_strong_app_password

# MARIADB_IMAGE=mariadb:10.11
