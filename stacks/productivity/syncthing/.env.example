# Official image tag — bump intentionally after reading upstream release notes.
SYNCTHING_IMAGE=syncthing/syncthing:2.0

TZ=UTC

# Short name shown to peers (optional).
SYNCTHING_HOSTNAME=syncthing

# Config + SQLite database live here on the host (UID/GID 1000 inside the image — chown host paths if needed).
SYNCTHING_CONFIG_DIR=./config

# Optional folder root — uncomment in compose.yaml after creating this directory.
# SYNCTHING_SYNC_DIR=./sync

# Web UI listen address inside the container (host port mapping uses SYNCTHING_GUI_PORT).
SYNCTHING_GUI_ADDRESS=0.0.0.0:8384

SYNCTHING_GUI_PORT=8384
SYNCTHING_SYNC_TCP_PORT=22000
SYNCTHING_SYNC_UDP_PORT=22000
SYNCTHING_LOCAL_DISCOVERY_UDP_PORT=21027
