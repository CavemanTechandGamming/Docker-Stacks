# --- Images (bump intentionally after reading upstream release notes) ---
PAPERLESS_IMAGE=ghcr.io/paperless-ngx/paperless-ngx:2.14
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

TZ=America/New_York

# --- PostgreSQL (Paperless uses the same values via PAPERLESS_DB*) ---
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Paperless core ---
# Long random string — changing it later invalidates sessions / tokens.
PAPERLESS_SECRET_KEY=change-me-long-random-secret-at-least-32-chars

# Base URL you use in the browser (scheme + host + port). Wrong value causes login / CSRF issues.
# Examples: http://192.168.1.50:8000  http://paperless.lan:8000
PAPERLESS_URL=http://127.0.0.1:8000

PAPERLESS_PORT=8000

# OCR language(s): https://docs.paperless-ngx.com/configuration/#ocr_settings
PAPERLESS_OCR_LANGUAGE=eng

# File ownership inside volumes (match your host user if you bind-mount extra paths).
PAPERLESS_UID=1000
PAPERLESS_GID=1000

# Drop PDFs and scans here — Paperless imports and removes them when configured to consume.
PAPERLESS_CONSUME_DIR=./consume

# Optional — first admin on a brand-new install only; blank after you have logged in once.
# PAPERLESS_ADMIN_USER=admin
# PAPERLESS_ADMIN_PASSWORD=change-me-admin-password
