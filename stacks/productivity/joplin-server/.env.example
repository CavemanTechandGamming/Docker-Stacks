# Pin intentionally — see https://hub.docker.com/r/joplin/server/tags
JOPLIN_SERVER_IMAGE=joplin/server:2
JOPLIN_POSTGRES_IMAGE=postgres:16-alpine

JOPLIN_PORT=22300

# Must match the URL you use in the browser and in Joplin (scheme + host + port + optional path).
# LAN example: http://192.168.1.50:22300
# Behind Caddy path prefix: https://notes.example.com/joplin
JOPLIN_BASE_URL=http://127.0.0.1:22300

JOPLIN_POSTGRES_DB=joplin
JOPLIN_POSTGRES_USER=joplin
JOPLIN_POSTGRES_PASSWORD=change-me-strong-db-password
