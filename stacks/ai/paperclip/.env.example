# Paperclip — https://github.com/paperclipai/paperclip / https://paperclip.inc/docs/deploy/docker
# If :latest fails to pull, pick a tag from: https://github.com/paperclipai/paperclip/pkgs/container/paperclip

PAPERCLIP_IMAGE=ghcr.io/paperclipai/paperclip:latest

PAPERCLIP_PORT=3100
# Must match how users reach the UI (scheme + host + port if non-default).
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# Required: long random secret for Better Auth (generate e.g. openssl rand -hex 32).
BETTER_AUTH_SECRET=

# Optional — enable in-container Claude / Codex adapters
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
