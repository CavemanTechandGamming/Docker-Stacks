# Timezone
TZ=America/New_York

# Prebuilt image; :latest tracks CUDA. For CPU-only hosts browse tags at:
# https://github.com/ai-dock/comfyui/pkgs/container/comfyui
COMFYUI_IMAGE=ghcr.io/ai-dock/comfyui:latest

# Published port on the host (inside the container ComfyUI listens on COMFYUI_INTERNAL_PORT)
COMFYUI_PORT=8188
COMFYUI_INTERNAL_PORT=8188

# Host folder mounted at WORKSPACE (models, custom nodes, outputs — see ComfyUI layout)
WORKSPACE_DIR=./workspace
WORKSPACE=/workspace

# Set true to pull ComfyUI updates on container start (optional)
AUTO_UPDATE=false

# Extra CLI args for ComfyUI, e.g. --highvram or --cpu (see ComfyUI docs)
COMFYUI_ARGS=

# AI-Dock defaults protect the service portal with auth; disable for trusted LAN or set credentials
WEB_ENABLE_AUTH=false
# WEB_USER=user
# WEB_PASSWORD=change-me

# Optional tokens for gated downloads
# HF_TOKEN=
# CIVITAI_TOKEN=
