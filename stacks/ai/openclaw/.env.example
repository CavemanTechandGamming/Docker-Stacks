# OpenClaw — https://github.com/openclaw/openclaw / https://docs.openclaw.ai/install/docker
# Pin the image tag in production (see GHCR package tags).

OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
# lan | loopback | custom | tailnet | auto — see upstream gateway docs
OPENCLAW_GATEWAY_BIND=lan

OPENCLAW_TZ=UTC

# Set after onboarding, or paste the token the wizard writes into mounted config.
# OPENCLAW_GATEWAY_TOKEN=

# Optional: set to 0 only if your Docker network supports mDNS (most bridge setups should leave default).
# OPENCLAW_DISABLE_BONJOUR=1
