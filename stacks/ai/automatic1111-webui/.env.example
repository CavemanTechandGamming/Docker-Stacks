# Timezone
TZ=America/New_York

# Image: universonic/stable-diffusion-webui tags include latest, minimal, full
WEBUI_IMAGE=universonic/stable-diffusion-webui:latest

# Host port for the Gradio UI (container listens on 8080)
WEBUI_PORT=8080

# Optional: absolute paths if you keep models on another disk
# MODELS_DIR=/srv/sd-webui/models
# OUTPUTS_DIR=/srv/sd-webui/outputs
# EXTENSIONS_DIR=/srv/sd-webui/extensions
# INPUTS_DIR=/srv/sd-webui/inputs
# EMBEDDINGS_DIR=/srv/sd-webui/embeddings
# LOCALIZATIONS_DIR=/srv/sd-webui/localizations
# TEXTUAL_INVERSION_DIR=/srv/sd-webui/textual_inversion_templates
