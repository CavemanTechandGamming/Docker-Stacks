# Host port exposed to localhost / your reverse proxy
WHOOGLE_PUBLISH_PORT=5000

# Override image tag deliberately on upgrades — https://hub.docker.com/r/benbusby/whoogle-search/tags
WHOOGLE_VERSION=1.2.4

# Optional HTTP basic auth (see https://github.com/benbusby/whoogle-search#installation )
#WHOOGLE_USER=
#WHOOGLE_PASS=
