PUID=1000
PGID=1000

# Full public URL (scheme + host + port if non-standard), e.g. http://192.168.1.50:3030 or https://git.example.com
FORGEJO_ROOT_URL=http://localhost:3030

FORGEJO_HTTP_PORT=3030
# Host port published for SSH clones; must match FORGEJO__server__SSH_PORT (advertised in UI).
FORGEJO_SSH_PORT=3022

# FORGEJO_IMAGE=docker.io/forgejo/forgejo:10
